# ─── Database ─────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USERNAME=erp_user
MYSQL_PASSWORD=erp_password
SPRING_DATASOURCE_URL=jdbc:postgresql://your-neon-host/your-database?sslmode=require
SPRING_DATASOURCE_USERNAME=your_neon_username
SPRING_DATASOURCE_PASSWORD=your_neon_password

# ─── Backend ──────────────────────────────────────────────────────
# IMPORTANT: Change this to a secure 64+ char random string in production
JWT_SECRET=springerpsecretkeywith512bitsforhs512algorithm12345678901234
SPRING_PROFILE=postgres

# ─── Email (Optional) ─────────────────────────────────────────────
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ─── Frontend ─────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_APP_NAME=SpringERP

